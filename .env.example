# Local OpenClaw Gateway endpoint (HTTP)
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789

# Optional bearer token if gateway auth is enabled
OPENCLAW_GATEWAY_TOKEN=

# Optional RPC paths (comma-separated). Default: /rpc,/api/rpc
OPENCLAW_GATEWAY_RPC_PATHS=/rpc,/api/rpc

# Default model/tool profile for spawned subagents
OPENCLAW_DEFAULT_MODEL=
OPENCLAW_TOOLS_PROFILE=coding

# Max run timeout in seconds accepted by API
OPENCLAW_RUN_TIMEOUT_MAX=1800

# ── Dashboard Branding (optional) ────────────────────
NEXT_PUBLIC_DASHBOARD_TITLE=OpenClaw Dashboard
NEXT_PUBLIC_DASHBOARD_LOGO=/logo.png
NEXT_PUBLIC_DASHBOARD_ACCENT_COLOR=#FF6B2B
NEXT_PUBLIC_OWNER_NAME=Owner
NEXT_PUBLIC_DASHBOARD_SUBTITLE=Mission Control
